@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h1>Admin Dashboard</h1>
    <p>Chào mừng Admin vào hệ thống quản lý checklist thông minh.</p>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card p-3">
                <h4>Quản lý tài khoản</h4>
                <p>Xem danh sách người dùng, vai trò và trạng thái tài khoản.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3">
                <h4>Quản lý role</h4>
                <p>Phân quyền Admin, Project Manager và Team Member.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3">
                <h4>Thống kê hệ thống</h4>
                <p>Theo dõi tình trạng tổng thể của toàn bộ hệ thống.</p>
            </div>
        </div>
    </div>
</div>