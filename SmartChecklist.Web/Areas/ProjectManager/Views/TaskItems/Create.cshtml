@model SmartChecklist.Web.Models.TaskItem

@{
    ViewData["Title"] = "Tạo công việc";
}

<div class="pm-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <h2 class="pm-section-title mb-2">Tạo công việc mới</h2>
            <p class="pm-muted mb-0">
                Checklist: <span class="fw-semibold">@ViewBag.ChecklistTitle</span>
            </p>
        </div>

        <a asp-action="Index"
               asp-route-checklistId="@ViewBag.ChecklistId"
               class="btn btn-outline-secondary">
            Quay lại danh sách công việc
        </a>
    </div>

    <form asp-action="Create" method="post" novalidate>
        <input type="hidden" asp-for="ChecklistId" value="@ViewBag.ChecklistId" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="pm-card h-100">
                    <h3 class="pm-section-title">Thông tin công việc</h3>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title"
                               class="form-control"
                               placeholder="Nhập tiêu đề công việc" />
                        <span asp-validation-for="Title" class="text-danger small"></span>

                        @if (ViewBag.SuggestedTaskTitles != null)
                        {
                            <div class="mt-3">
                                <div class="pm-muted small mb-2">Gợi ý công việc gần đây</div>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (string item in ViewBag.SuggestedTaskTitles)
                                    {
                                        <span class="pm-badge pm-badge-info">@item</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="5"
                                  placeholder="Mô tả chi tiết công việc"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Deadline" class="form-label fw-semibold"></label>
                            <input asp-for="Deadline"
                                   type="datetime-local"
                                   class="form-control"
                                   value="@(ViewBag.AiDeadline ?? (Model?.Deadline.HasValue == true ? Model.Deadline.Value.ToString("yyyy-MM-ddTHH:mm") : ""))" />
                            <span asp-validation-for="Deadline" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="AssignedToUserId" class="form-label fw-semibold">Người phụ trách</label>
                            <select asp-for="AssignedToUserId"
                                    class="form-select"
                                    asp-items="ViewBag.AssignedToUserId">
                                <option value="">-- Chọn thành viên --</option>
                            </select>
                            <span asp-validation-for="AssignedToUserId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Priority" class="form-label fw-semibold"></label>
                            <select asp-for="Priority" class="form-select">
                                <option value="Thấp">Thấp</option>
                                <option value="Trung bình">Trung bình</option>
                                <option value="Cao">Cao</option>
                                <option value="Khẩn cấp">Khẩn cấp</option>
                            </select>
                            <span asp-validation-for="Priority" class="text-danger small"></span>

                            @if (ViewBag.AiPriority != null)
                            {
                                <div class="mt-2">
                                    <span class="pm-badge pm-badge-warning">
                                        Gợi ý ưu tiên: @ViewBag.AiPriority
                                    </span>
                                </div>
                            }
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label fw-semibold"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Chưa thực hiện">Chưa thực hiện</option>
                                <option value="Đang thực hiện">Đang thực hiện</option>
                                <option value="Hoàn thành">Hoàn thành</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="pm-card mb-4">
                    <h3 class="pm-section-title">Hỗ trợ AI</h3>
                    <p class="pm-muted">
                        Dựa trên người phụ trách, hệ thống có thể gợi ý deadline và mức ưu tiên phù hợp.
                    </p>

                    <form asp-action="GetAiSuggestions" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="checklistId" value="@ViewBag.ChecklistId" />
                        <input type="hidden" name="assignedToUserId" id="assignedToUserIdHidden" />
                        <button type="submit" class="btn btn-outline-primary w-100">
                            Gợi ý AI
                        </button>
                    </form>
                </div>

                <div class="pm-card">
                    <h3 class="pm-section-title">Thao tác</h3>
                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-success">
                            Lưu công việc
                        </button>

                        <a asp-action="Index"
                               asp-route-checklistId="@ViewBag.ChecklistId"
                               class="btn btn-outline-secondary">
                            Hủy và quay lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const selectAssigned = document.getElementById("AssignedToUserId");
        const hiddenAssigned = document.getElementById("assignedToUserIdHidden");

        if (selectAssigned && hiddenAssigned) {
            hiddenAssigned.value = selectAssigned.value;

            selectAssigned.addEventListener("change", function () {
                hiddenAssigned.value = this.value;
            });
        }
    </script>
}