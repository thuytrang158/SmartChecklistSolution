@model SmartChecklist.Web.Models.Project

@{
    ViewData["Title"] = "Xóa dự án";
}

<div class="pm-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <h2 class="pm-section-title mb-2 text-danger">Xác nhận xóa dự án</h2>
            <p class="pm-muted mb-0">
                Hành động này sẽ ẩn dự án khỏi hệ thống quản lý của bạn.
            </p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Quay lại danh sách
        </a>
    </div>

    <div class="alert alert-danger">
        Bạn có chắc muốn xóa dự án này không? Thao tác này có thể ảnh hưởng đến checklist, công việc và thành viên liên quan.
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="pm-card h-100">
                <h3 class="pm-section-title">Thông tin dự án</h3>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="pm-muted small mb-1">Tên dự án</div>
                            <div class="fw-bold">@Model.Name</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="pm-muted small mb-1">Trạng thái</div>
                            <div class="fw-bold">@Model.Status</div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="pm-muted small mb-1">Ngày bắt đầu</div>
                            <div class="fw-bold">
                                @(Model.StartDate.HasValue? Model.StartDate.Value.ToString("dd/MM/yyyy") : "Chưa đặt")
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="border rounded-4 p-3 h-100">
                            <div class="pm-muted small mb-1">Ngày kết thúc</div>
                            <div class="fw-bold">
                                @(Model.EndDate.HasValue? Model.EndDate.Value.ToString("dd/MM/yyyy") : "Chưa đặt")
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="border rounded-4 p-3">
                            <div class="pm-muted small mb-2">Mô tả</div>
                            @if (!string.IsNullOrWhiteSpace(Model.Description))
                            {
                                <div>@Model.Description</div>
                            }
                            else
                            {
                                <div class="pm-muted">Dự án này chưa có mô tả.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="pm-card">
                <h3 class="pm-section-title">Thao tác</h3>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ProjectId" />

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-danger">
                            Xác nhận xóa dự án
                        </button>

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Hủy và quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>