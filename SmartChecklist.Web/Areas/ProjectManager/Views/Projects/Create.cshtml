@model SmartChecklist.Web.Models.Project

@{
    ViewData["Title"] = "Tạo dự án";
}

<div class="pm-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <h2 class="pm-section-title mb-2">Tạo dự án mới</h2>
            <p class="pm-muted mb-0">
                Khởi tạo một dự án mới để bắt đầu quản lý checklist, công việc và thành viên.
            </p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Quay lại danh sách
        </a>
    </div>

    <form asp-action="Create" method="post" novalidate>
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="pm-card h-100">
                    <h3 class="pm-section-title">Thông tin cơ bản</h3>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên dự án" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="5"
                                  placeholder="Mô tả ngắn về mục tiêu, phạm vi hoặc ghi chú của dự án"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label fw-semibold"></label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-semibold"></label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="pm-card mb-4">
                    <h3 class="pm-section-title">Lưu ý</h3>
                    <ul class="mb-0 ps-3">
                        <li class="mb-2">Tên dự án nên ngắn gọn, dễ nhận diện.</li>
                        <li class="mb-2">Ngày kết thúc nên lớn hơn hoặc bằng ngày bắt đầu.</li>
                        <li>Trạng thái mặc định sẽ là <strong>Mới tạo</strong>.</li>
                    </ul>
                </div>

                <div class="pm-card">
                    <h3 class="pm-section-title">Thao tác</h3>
                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-success">
                            Lưu dự án
                        </button>

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Hủy và quay lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}