@model SmartChecklist.Web.Models.Checklist

@{
    ViewData["Title"] = "Tạo checklist";
}

<div class="pm-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <h2 class="pm-section-title mb-2">Tạo checklist mới</h2>
            <p class="pm-muted mb-0">
                Dự án: <span class="fw-semibold">@ViewBag.ProjectName</span>
            </p>
        </div>

        <a asp-action="Index"
               asp-route-projectId="@ViewBag.ProjectId"
               class="btn btn-outline-secondary">
            Quay lại danh sách checklist
        </a>
    </div>

    <form asp-action="Create" method="post" novalidate>
        <input type="hidden" asp-for="ProjectId" value="@ViewBag.ProjectId" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="pm-card h-100">
                    <h3 class="pm-section-title">Thông tin checklist</h3>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title"
                               class="form-control"
                               placeholder="Nhập tên checklist" />
                        <span asp-validation-for="Title" class="text-danger small"></span>

                        @if (ViewBag.SuggestedTitles != null)
                        {
                            <div class="mt-3">
                                <div class="pm-muted small mb-2">Gợi ý tiêu đề từ AI</div>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (string item in ViewBag.SuggestedTitles)
                                    {
                                        <span class="pm-badge pm-badge-info">@item</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="5"
                                  placeholder="Mô tả mục tiêu hoặc nội dung chính của checklist"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="WorkType" class="form-label fw-semibold"></label>
                        <input asp-for="WorkType"
                               class="form-control"
                               placeholder="Ví dụ: Thiết kế, Kiểm thử, Phát triển, Triển khai..." />
                        <span asp-validation-for="WorkType" class="text-danger small"></span>

                        @if (ViewBag.SuggestedWorkTypes != null)
                        {
                            <div class="mt-3">
                                <div class="pm-muted small mb-2">Gợi ý loại công việc</div>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (string item in ViewBag.SuggestedWorkTypes)
                                    {
                                        <span class="pm-badge pm-badge-warning">@item</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="pm-card mb-4">
                    <h3 class="pm-section-title">Lưu ý</h3>
                    <ul class="mb-0 ps-3">
                        <li class="mb-2">Tên checklist nên ngắn gọn, bám sát mục tiêu công việc.</li>
                        <li class="mb-2">Mỗi checklist nên đại diện cho một nhóm việc rõ ràng.</li>
                        <li>Có thể dùng gợi ý AI để đặt tiêu đề và loại công việc nhanh hơn.</li>
                    </ul>
                </div>

                <div class="pm-card">
                    <h3 class="pm-section-title">Thao tác</h3>
                    <div class="d-grid gap-3">
                        <button type="submit" class="btn btn-success">
                            Lưu checklist
                        </button>

                        <a asp-action="Index"
                               asp-route-projectId="@ViewBag.ProjectId"
                               class="btn btn-outline-secondary">
                            Hủy và quay lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}