@model IEnumerable<SmartChecklist.Web.Models.TaskItem>

@{
    ViewData["Title"] = "Công việc của tôi";
}

<div class="mb-4">
    <h2 class="mb-2">Công việc của tôi</h2>
    <p class="text-muted mb-0">
        Theo dõi các công việc được giao, deadline và cập nhật trạng thái nhanh.
    </p>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Danh sách công việc</h5>
        <span class="text-muted small">Tổng: @Model.Count() công việc</span>
    </div>

    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-light border mb-0">
                Bạn chưa có công việc nào được giao.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Tiêu đề</th>
                            <th>Dự án</th>
                            <th>Checklist</th>
                            <th>Deadline</th>
                            <th>Ưu tiên</th>
                            <th>Trạng thái</th>
                            <th style="min-width: 240px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var isOverdue = item.Deadline.HasValue
                                && item.Deadline.Value < DateTime.Now
                                && item.Status != "Hoàn thành";

                            <tr>
                                <td class="fw-semibold">@item.Title</td>
                                <td>@(item.Checklist?.Project?.Name ?? "-")</td>
                                <td>@(item.Checklist?.Title ?? "-")</td>
                                <td>
                                    @if (item.Deadline.HasValue)
                                    {
                                        <div>@item.Deadline.Value.ToString("dd/MM/yyyy")</div>
                                        <div class="small text-muted">@item.Deadline.Value.ToString("HH:mm")</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa có hạn</span>
                                    }

                                    @if (isOverdue)
                                    {
                                        <div class="small text-danger fw-semibold">Quá hạn</div>
                                    }
                                </td>
                                <td>
                                    @if (item.Priority == "Cao")
                                    {
                                        <span class="badge bg-danger">Cao</span>
                                    }
                                    else if (item.Priority == "Khẩn cấp")
                                    {
                                        <span class="badge bg-danger">Khẩn cấp</span>
                                    }
                                    else if (item.Priority == "Trung bình")
                                    {
                                        <span class="badge bg-warning text-dark">Trung bình</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Priority</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Status == "Hoàn thành")
                                    {
                                        <span class="badge bg-success">Hoàn thành</span>
                                    }
                                    else if (item.Status == "Đang thực hiện")
                                    {
                                        <span class="badge bg-primary">Đang thực hiện</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a asp-action="Details"
                                               asp-route-id="@item.TaskItemId"
                                               class="btn btn-outline-secondary btn-sm">
                                            Chi tiết
                                        </a>

                                        @if (item.Status != "Đang thực hiện")
                                        {
                                            <form asp-action="UpdateStatus" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.TaskItemId" />
                                                <input type="hidden" name="newStatus" value="Đang thực hiện" />
                                                <button type="submit" class="btn btn-primary btn-sm">
                                                    Đang TH
                                                </button>
                                            </form>
                                        }

                                        @if (item.Status != "Hoàn thành")
                                        {
                                            <form asp-action="UpdateStatus" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.TaskItemId" />
                                                <input type="hidden" name="newStatus" value="Hoàn thành" />
                                                <button type="submit" class="btn btn-success btn-sm">
                                                    Hoàn thành
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>